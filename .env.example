# CCE Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Gumroad Licence Key (required)
LICENCE_KEY=
GUMROAD_PRODUCT_ID=your_product_id_here

# Safety — always start true, change to false only when ready for live trading
CCE_DRY_RUN=true
STARTING_CAPITAL=300
CIRCUIT_BREAKER_PCT=-20
BASE_CURRENCY=USD

# Kraken API — trading permissions only, NO withdrawal permissions
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Telegram notifications (optional but recommended)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard emergency stop authentication
DASHBOARD_STOP_TOKEN=

# LunarCrush (optional, requires Builder plan)
LUNARCRUSH_API_KEY=

# Claude (optional - enables AI-powered optimisation suggestions)
ANTHROPIC_API_KEY=